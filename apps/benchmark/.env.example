# Target: direct Mongo or Nance proxy URI (from dashboard "Create access")
MONGO_URI=mongodb://demo:TOKEN@127.0.0.1:27018/?authMechanism=PLAIN&authSource=$external&directConnection=true

MONGO_DB=loadtest
MONGO_COLLECTION=loadtest_docs

# Document payload size for writes/seed (bytes)
DOC_SIZE=512

# Seed at least this many docs before heavy read tests (scripts/seed.py or first write users)
SEED_COUNT=5000

# Optional: force direct connection (recommended for Nance proxy)
MONGO_DIRECT=true
